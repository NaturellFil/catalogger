# source this before running catalogger / mitmdump
export CATALOGGER_DSN="postgresql://catalogger:changeme@127.0.0.1:5432/catalogger"
# set per Claude Code hunting session so flows are attributable:
export CATALOGGER_PROGRAM="my-program"
export CATALOGGER_SESSION="$(date +%Y%m%d-%H%M)"   # or your Claude Code session id
# export CATALOGGER_COLLAPSE=1   # collapse mode for high-volume fuzz streams
